<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Separator?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.weather.WeatherController"
      prefWidth="420" prefHeight="560"
      spacing="16" alignment="TOP_CENTER">

    <padding>
        <Insets top="24" bottom="24" left="24" right="24"/>
    </padding>

    <!-- TÍTULO -->
    <Label text="Aplicación del Tiempo"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"
           maxWidth="Infinity"
           alignment="CENTER"/>

    <!-- BARRA DE BÚSQUEDA -->
    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="cityTextField"
                   promptText="Introduce el nombre de la ciudad..."
                   HBox.hgrow="ALWAYS"
                   onAction="#handleSearch"/>
        <Button text="Buscar" onAction="#handleSearch"/>
    </HBox>

    <!-- MENSAJE DE ERROR -->
    <Label fx:id="errorLabel"
           text=""
           style="-fx-text-fill: red;"
           maxWidth="Infinity"
           alignment="CENTER"/>

    <Separator/>

    <!-- TARJETA DE RESULTADOS -->
    <VBox fx:id="resultCard" spacing="12" alignment="CENTER"
          visible="false" managed="false">

        <!-- Ciudad -->
        <Label fx:id="cityNameLabel"
               text=""
               style="-fx-font-size: 20px; -fx-font-weight: bold;"
               maxWidth="Infinity"
               alignment="CENTER"/>

        <!-- Descripción -->
        <Label fx:id="descriptionLabel"
               text=""
               style="-fx-font-size: 14px;"
               maxWidth="Infinity"
               alignment="CENTER"/>

        <!-- Icono + Temperatura -->
        <HBox spacing="16" alignment="CENTER">
            <ImageView fx:id="weatherIcon"
                       fitWidth="64" fitHeight="64"
                       preserveRatio="true"/>
            <Label fx:id="temperatureLabel"
                   text=""
                   style="-fx-font-size: 40px; -fx-font-weight: bold;"/>
        </HBox>

        <Separator/>

        <!-- Humedad / Viento / Sensación -->
        <HBox spacing="0" alignment="CENTER">

            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="💧 Humedad" style="-fx-font-size: 12px;"/>
                <Label fx:id="humidityLabel" text=""
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="💨 Viento" style="-fx-font-size: 12px;"/>
                <Label fx:id="windSpeedLabel" text=""
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

            <Separator orientation="VERTICAL"/>

            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label text="🌡 Sensación" style="-fx-font-size: 12px;"/>
                <Label fx:id="feelsLikeLabel" text=""
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </VBox>

        </HBox>

    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- FOOTER -->
    <Label text="Datos: OpenWeatherMap"
           style="-fx-font-size: 11px; -fx-text-fill: gray;"
           maxWidth="Infinity"
           alignment="CENTER"/>

</VBox>
